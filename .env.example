# Redbelly RPC endpoint
# Default: public mainnet governors node — override if running a private node
REDBELLY_RPC_URL=https://governors.mainnet.redbelly.network

# Routescan API key (optional)
# The free tier allows 2 req/s and 10,000 calls/day.
# Each /api/metrics poll makes 12 Routescan calls, so a single sustained visitor
# exhausts the free tier in ~7 hours. Get a key at routescan.io to raise the limit.
ROUTESCAN_API_KEY=
